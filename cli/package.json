{
  "name": "@fiber-dev-kit/cli",
  "version": "0.1.0",
  "description": "Fiber Dev Kit CLI for running Fiber nodes quickly from npm",
  "license": "MIT",
  "private": false,
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/scisamir/fiber-dev-kit.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/scisamir/fiber-dev-kit/issues"
  },
  "homepage": "https://github.com/scisamir/fiber-dev-kit#readme",
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "bin": {
    "fiber": "dist/fiber.js"
  },
  "main": "./dist/fiber.js",
  "files": [
    "README.md",
    "dist",
    "config",
    "docs",
    "vendor"
  ],
  "os": [
    "linux"
  ],
  "cpu": [
    "x64"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/fiber.js",
    "typecheck": "tsc --noEmit",
    "prepack": "npm run build",
    "smoke": "npm run build && node dist/fiber.js version"
  },
  "dependencies": {
    "@fiber-dev-kit/inspector": "0.1.0",
    "chalk": "^5.6.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  },
  "engines": {
    "node": ">=18"
  }
}
