{
  "name": "fiber-dev-kit-example",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Minimal Fiber Dev Kit example project for docs and judges",
  "scripts": {
    "setup": "fiber start --nodes 2 --channel 200",
    "status": "fiber status",
    "pay": "fiber pay --from a --to b --amount 1",
    "inspect": "fiber inspect",
